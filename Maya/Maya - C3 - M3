CONTEXT
		C3 	›
	EXTENDS
	⚬	 C0 
	SETS
	⚬	ETAT_RESERVATION	 ›
	CONSTANTS
	⚬	valide	 ›
	⚬	invalide	 ›
	⚬	reservation	 ›
	AXIOMS
	⚬	axm1:	ETAT_RESERVATION = {valide, invalide}  not theorem ›
	⚬	axm2:	valide ≠ invalide not theorem ›
	⚬	axm3:	reservation ∈ VEHICULE → ETAT_RESERVATION  not theorem ›
	⚬	axm4:	valide ∈ ETAT_RESERVATION not theorem ›
	⚬	axm5:	invalide ∈ ETAT_RESERVATION not theorem ›
	END

//M3
MACHINE
		M3 	›
	REFINES
	⚬	 M0 
	SEES
	⚬	 C3 
	VARIABLES
	⚬	places_pont1	 ›
	⚬	places_pont2	 ›
	⚬	places_pont3	 ›
	⚬	permission_envoyee	 ›
	INVARIANTS
	⚬	inv1:	places_pont1 ∈ ℤ not theorem ›
	⚬	inv2:	places_pont1 ≤ N not theorem ›
	⚬	inv7:	places_pont1 ≥ 0  not theorem ›
	⚬	inv3:	places_pont2 ∈ ℤ not theorem ›
	⚬	inv4:	places_pont2 ≤ N not theorem ›
	⚬	inv8:	places_pont2 ≥ 0 not theorem ›
	⚬	inv5:	places_pont3 ∈ ℤ not theorem ›
	⚬	inv6:	places_pont3 ≤ N not theorem ›
	⚬	inv9:	places_pont3 ≥ 0 not theorem ›
	⚬	inv10:	permission_envoyee ∈ BOOL  not theorem ›
	EVENTS
	⚬	INITIALISATION:	 not extended ordinary ›
		THEN
		⚬	act1:	places_pont1 ≔ 0 ›
		⚬	act2:	places_pont2 ≔ 0 ›
		⚬	act3:	places_pont3 ≔ 0 ›
		⚬	act4:	permission_envoyee ≔ FALSE ›
		END

	⚬	monter_pont1:	 extended ordinary ›
		REFINES
		⚬	 monter_pont1 
		ANY
		⚬	v	 ›
		WHERE
		⚬	grd1:	v ∈ TYPE_VEHICULE  not theorem ›
		⚬	grd2:	places_pont1 + taille(v) ≤ N not theorem ›
		⚬	grd3:	places_pont1 ≥ 0 not theorem ›
		⚬	grd4:	permission_envoyee = TRUE not theorem ›
		⚬	grd5:	places_pont1 + taille(v) ≥ 0 not theorem ›
		THEN
		⚬	act1:	places_pont1 ≔ places_pont1 + taille(v) ›
		⚬	act2:	permission_envoyee ≔ FALSE ›
		END

	⚬	monter_pont2:	 extended ordinary ›
		REFINES
		⚬	 monter_pont2 
		ANY
		⚬	v	 ›
		WHERE
		⚬	grd1:	v ∈ TYPE_VEHICULE not theorem ›
		⚬	grd2:	places_pont1 = N not theorem ›
		⚬	grd3:	places_pont2 + taille(v) ≤ N not theorem ›
		⚬	grd4:	places_pont2 ≥ 0 not theorem ›
		⚬	grd5:	taille(v) ≥ 0 not theorem ›
		⚬	grd6:	permission_envoyee = TRUE not theorem ›
		⚬	grd7:	places_pont2 + taille(v) ≥ 0 not theorem ›
		THEN
		⚬	act1:	places_pont2 ≔ places_pont2 + taille(v) ›
		⚬	act2:	permission_envoyee ≔ FALSE ›
		END

	⚬	monter_pont3:	 extended ordinary ›
		REFINES
		⚬	 monter_pont3 
		ANY
		⚬	v	 ›
		WHERE
		⚬	grd1:	v ∈ TYPE_VEHICULE not theorem ›
		⚬	grd2:	places_pont1 = N theorem ›
		⚬	grd3:	places_pont2 = N not theorem ›
		⚬	grd4:	places_pont3 + taille(v) ≤ N not theorem ›
		⚬	grd5:	places_pont3 ≥ 0 not theorem ›
		⚬	grd6:	permission_envoyee = TRUE  not theorem ›
		⚬	grd7:	places_pont3 + taille(v) ≥ 0 not theorem ›
		THEN
		⚬	act1:	places_pont3 ≔ places_pont3 + taille(v) ›
		⚬	act2:	permission_envoyee ≔ FALSE ›
		END

	⚬	verification_reservation:	 not extended ordinary ›
		ANY
		⚬	v	 ›
		WHERE
		⚬	grd1:	v ∈ VEHICULE not theorem ›
		⚬	grd2:	reservation(v) = valide not theorem ›
		⚬	grd3:	permission_envoyee = FALSE not theorem ›
		THEN
		⚬	act1:	permission_envoyee ≔ TRUE ›
		END

	⚬	rejet_vehicule:	 not extended ordinary ›
		ANY
		⚬	v	 ›
		WHERE
		⚬	grd1:	v ∈ VEHICULE not theorem ›
		⚬	grd2:	reservation(v) = invalide not theorem ›
		END
END


  vertex(880, 492); vertex(150, 492);
  endShape(CLOSE);

  fill(95, 100, 115); stroke(75, 80, 95); strokeWeight(1);
  rect(170, 432, 680, 58);
  fill(105, 110, 125);
  rect(190, 295, 640, 58);
  fill(115, 120, 135);
  rect(210, 158, 600, 58);

  fill(175, 180, 195); noStroke();
  rect(670, 90, 110, 78);
  fill(140, 195, 255);
  rect(680, 102, 20, 14, 3);
  rect(710, 102, 20, 14, 3);
  rect(740, 102, 20, 14, 3);

  fill(45, 45, 55);
  rect(720, 38, 20, 58);
  fill(190, 190, 190, 110); noStroke();

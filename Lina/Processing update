// ============================================
// POPUP
// ============================================
void dessinerPopup() {
  fill(0,0,0,155); noStroke(); rect(0,0,width,height);
  float px=width/2-210, py=height/2-170;
  fill(28,28,52); stroke(145,145,250); strokeWeight(2);
  rect(px,py,420,340,10);
  fill(255,215,90); textAlign(CENTER); textSize(15);
  text("Ajouter un vehicule", width/2, py+28);
  fill(175,175,225); textSize(10);
  text("Clic = resa valide   |   Shift+Clic = resa invalide", width/2, py+48);

  String[] noms2={"Voiture (t1)","Camion1 (t1)","Camion2 (t2)","Camion3 (t3)"};
  color[] cols={color(65,125,210),color(45,150,70),color(210,125,35),color(190,55,55)};
  for (int i=0; i<4; i++) {
    float tx=px+15+(i%2)*200, ty=py+60+(i/2)*115;
    boolean sv=mouseX>tx && mouseX<tx+185 && mouseY>ty && mouseY<ty+100;
    fill(sv?lerpColor(cols[i],color(255),0.25):cols[i]);
    stroke(255); strokeWeight(1); rect(tx,ty,185,100,8);
    dessinerVeh(i+1,tx+12,ty+32);
    fill(255); textAlign(LEFT); textSize(11);
    text(noms2[i], tx+72, ty+48);
    fill(220,220,255); textSize(9);
    text("Clic = valide", tx+72, ty+65);
    text("Shift = invalide", tx+72, ty+78);
  }

  float cx=px+385, cy=py+8;
  boolean sc=mouseX>cx && mouseX<cx+28 && mouseY>cy && mouseY<cy+24;
  fill(sc?color(195,45,45):color(145,25,25));
  stroke(250,95,95); rect(cx,cy,28,24,5);
  fill(255); textAlign(CENTER); textSize(12);
  text("X", cx+14, cy+16);
}

// ============================================
// CLICS
// ============================================
void mousePressed() {
  if (popup) {
    float px=width/2-210, py=height/2-170;
    if (mouseX>px+385 && mouseX<px+413 && mouseY>py+8 && mouseY<py+32) {
      popup=false; return;
    }
    for (int i=0; i<4; i++) {
      float tx=px+15+(i%2)*200, ty=py+60+(i/2)*115;
      if (mouseX>tx && mouseX<tx+185 && mouseY>ty && mouseY<ty+100) {
        boolean r=!keyPressed || keyCode!=SHIFT;
        addVeh(i+1,r);
        msg=nomType(i+1)+" ajoute ("+(r?"valide":"invalide")+")";
        popup=false; return;
      }
    }
    return;
  }

  for (int i=0; i<8; i++) {
    float bx=10+(i%5)*115;
    float by=(i<5)?height-88:height-44;
    if (mouseX>bx && mouseX<bx+108 && mouseY>by && mouseY<by+36) {
      autoMode=false;
      faireEtapeNum(i); return;
    }
  }

  if (mouseX>width-132 && mouseX<width-7
   && mouseY>height-140 && mouseY<height-104) {
    popup=true; return;
  }
  if (mouseX>width-132 && mouseX<width-7
   && mouseY>height-92 && mouseY<height-56) {
    autoMode=!autoMode;
    msg=autoMode?"Mode auto active !":"Auto en pause.";
    return;
  }
  if (mouseX>width-132 && mouseX<width-7
   && mouseY>height-44 && mouseY<height-8) {
    reset(); return;
  }
}

void faireEtapeNum(int i) {
  switch(i) {
    case 0: verifResa(); break;
    case 1: ouvrirEntree(); break;
    case 2: chargerMC(); break;
    case 3: ouvrirSortie(); break;
    case 4: monterPont(); break;
    case 5: versPont2(); break;
    case 6: versPont3(); break;
    case 7: versPont1(); break;
  }
}

  for (int i = 0; i < nP1; i++) dessinerVeh(vP1[i], 190+i*34, 438);
  for (int i = 0; i < nP2; i++) dessinerVeh(vP2[i], 210+i*34, 301);
  for (int i = 0; i < nP3; i++) dessinerVeh(vP3[i], 230+i*34, 164);
}

// ============================================
// VEHICULE
// ============================================
void dessinerVeh(int type, float x, float y) {
  noStroke();
  if (type == 1) {
    fill(65,125,215); rect(x,y+5,24,12,3);
    fill(145,195,255); rect(x+4,y+3,14,8,2);
    fill(15,15,15); ellipse(x+5,y+17,7,7); ellipse(x+19,y+17,7,7);
  } else if (type == 2) {
    fill(45,155,75); rect(x,y+4,26,14,2);
    fill(145,250,175); rect(x+2,y+2,10,8,2);
    fill(15,15,15); ellipse(x+6,y+18,7,7); ellipse(x+20,y+18,7,7);
  } else if (type == 3) {
    fill(215,125,35); rect(x,y+3,40,15,2);
    fill(250,195,145); rect(x+2,y+1,12,9,2);
    fill(15,15,15); ellipse(x+7,y+18,8,8); ellipse(x+32,y+18,8,8);
  } else if (type == 4) {
    fill(195,55,55); rect(x,y+2,54,16,2);
    fill(250,145,145); rect(x+2,y,14,10,2);
    fill(15,15,15); ellipse(x+8,y+18,8,8);
    ellipse(x+30,y+18,8,8); ellipse(x+46,y+18,8,8);
  }
  fill(255,215,0); textAlign(CENTER); textSize(8);
  text(labelType(type), x+taille(type)*12, y-1);
}

// ============================================
// MONTE-CHARGE
// ============================================
void dessinerMC() {
  stroke(110,110,130); strokeWeight(5);
  line(140,148,140,492);
  strokeWeight(2);
  for (float y=492; y>148; y-=16) line(129,y,151,y);

  fill(mcBouge ? color(255,195,0) : color(55,175,55));
  stroke(35,35,35); strokeWeight(2);
  rect(103, mcY, 74, 58, 5);

  stroke(barrEntree ? color(45,215,45) : color(215,45,45)); strokeWeight(4);
  line(103, mcY+10, 103, mcY-16);
  stroke(barrSortie ? color(45,215,45) : color(215,45,45));
  line(177, mcY+10, 177, mcY-16);

  int col=0, row=0;
  for (int i=0; i<nMC; i++) {
    dessinerVeh(vMC[i], 106+col*34, mcY+4+row*24);
    col++;
    if (col >= 2) { col=0; row++; }
  }

  fill(255); noStroke(); textAlign(CENTER); textSize(10);
  text("MC "+placesMC+"/6", 140, mcY+53);
  fill(255,215,90); textSize(9);
  text("P"+(niveau+1), 140, mcY-5);

  if (mcBouge) {
    fill(255,215,0); noStroke();
    float d = mcYcible < mcY ? -1 : 1;
    triangle(140, mcY+d*65, 132, mcY+d*50, 148, mcY+d*50);
  }
}

// ============================================
// FILE
// ============================================
void dessinerFile() {
  fill(25,25,48); noStroke();
  rect(8,132,90,370,8);
  fill(255,215,90); textAlign(CENTER); textSize(10);
  text("FILE", 53, 152);
  text((nbFile-tete)+" veh.", 53, 164);

  int show=0;
  for (int i=tete; i<nbFile && show<8; i++) {
    float fy = 170+show*44;
    fill(resas[i] ? color(25,95,25) : color(95,25,25));
    noStroke(); rect(12,fy,78,34,5);
    dessinerVeh(file[i],14,fy+7);
    fill(255); textSize(9); textAlign(RIGHT);
    text(resas[i]?"OK":"KO", 86, fy+22);
    if (i==tete) {
      fill(255,215,0); noStroke();
      triangle(102,fy+17,94,fy+10,94,fy+24);
    }
    show++;
  }
}

// ============================================
// BOUTONS
// ============================================
void dessinerBoutons() {
  String[] noms = {
    "1. Verif Resa",
    "2. Ouvrir Entree",
    "3. Charger MC",
    "4. Ouvrir Sortie",
    "5. Monter Pont",
    "^ Pont 2",
    "^ Pont 3",
    "v Pont 1"
  };

  for (int i=0; i<8; i++) {
    float bx = 10+(i%5)*115;
    float by = (i<5) ? height-88 : height-44;
    float bw=108, bh=36;
    boolean survol = mouseX>bx && mouseX<bx+bw && mouseY>by && mouseY<by+bh;
    boolean actif = (i==etape);

    if (actif && !autoMode) {
      float p = 0.5+0.5*sin(frameCount*0.12);
      fill(lerpColor(color(25,120,25),color(55,215,55),p));
      stroke(90,250,90); strokeWeight(2);
      fill(255,215,0); noStroke();
      triangle(bx+bw/2,by-4,bx+bw/2-7,by-15,bx+bw/2+7,by-15);
      float p2 = 0.5+0.5*sin(frameCount*0.12);
      fill(lerpColor(color(25,120,25),color(55,215,55),p2));
      stroke(90,250,90); strokeWeight(2);
    } else if (survol) {
      fill(75,75,175); stroke(145,145,250); strokeWeight(1);
    } else {
      fill(45,45,115); stroke(95,95,175); strokeWeight(1);
    }

    rect(bx,by,bw,bh,6);
    fill(actif && !autoMode ? color(255) : color(195,195,250));
    textAlign(CENTER); textSize(10);
    text(noms[i], bx+bw/2, by+bh/2+4);
  }

  // Bouton Ajouter
  float ax=width-132, ay=height-140;
  boolean sa=mouseX>ax && mouseX<ax+125 && mouseY>ay && mouseY<ay+36;
  fill(sa?color(95,55,155):color(65,25,125));
  stroke(175,95,250); strokeWeight(2);
  rect(ax,ay,125,36,6);
  fill(255); textAlign(CENTER); textSize(10);
  text("Ajouter Vehicule", ax+62, ay+22);

  // Bouton Auto
  float bax=width-132, bay=height-92;
  boolean sb=mouseX>bax && mouseX<bax+125 && mouseY>bay && mouseY<bay+36;
  if (autoMode) {
    float p=0.5+0.5*sin(frameCount*0.1);
    fill(lerpColor(color(175,75,0),color(255,145,0),p));
    stroke(255,195,0); strokeWeight(3);
  } else {
    fill(sb?color(0,115,55):color(0,85,38));
    stroke(0,215,95); strokeWeight(2);
  }
  rect(bax,bay,125,36,6);
  fill(255); textAlign(CENTER); textSize(10);
  text(autoMode?"PAUSE":"MODE AUTO", bax+62, bay+22);

  // Bouton Reset
  float rx=width-132, ry=height-44;
  boolean sr=mouseX>rx && mouseX<rx+125 && mouseY>ry && mouseY<ry+36;
  fill(sr?color(155,35,35):color(115,18,18));
  stroke(250,75,75); strokeWeight(2);
  rect(rx,ry,125,36,6);
  fill(255); textAlign(CENTER); textSize(10);
  text("RESET", rx+62, ry+22);
}


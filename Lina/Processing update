// ============================================
// FERRY BOAT - INFOB236 - Groupe 10
// ============================================

// Variables principales
int N = 20;
int pont1 = 0, pont2 = 0, pont3 = 0;
int niveau = 0;
boolean mcBouge = false;
int placesMC = 0;
boolean barrEntree = false;
boolean barrSortie = false;
boolean permission = false;

// Position visuelle du monte-charge
float mcY = 420;
float mcYcible = 420;

// File d'attente
int[] file = new int[50];
boolean[] resas = new boolean[50];
int nbFile = 0;
int tete = 0;

// Vehicules sur les ponts
int[] vP1 = new int[20], vP2 = new int[20], vP3 = new int[20];
int nP1 = 0, nP2 = 0, nP3 = 0;
int[] vMC = new int[6];
int nMC = 0;

// Guidage
int etape = 0;
String msg = "Ajoutez des vehicules puis cliquez le bouton vert !";

// Mode auto
boolean autoMode = false;
int autoTimer = 0;

// Popup
boolean popup = false;

// ============================================
void setup() {
  size(1000, 620);
  addVeh(1, true);
  addVeh(3, true);
  addVeh(4, false);
  addVeh(2, true);
  addVeh(1, true);
  addVeh(3, true);
  addVeh(4, true);
  addVeh(1, true);
}

// ============================================
// Utilitaires
// ============================================
void addVeh(int type, boolean resa) {
  if (nbFile >= 50) return;
  file[nbFile] = type;
  resas[nbFile] = resa;
  nbFile++;
}

int taille(int v) {
  if (v == 3) return 2;
  if (v == 4) return 3;
  return 1;
}

String nomType(int v) {
  String[] noms = {"", "Voiture", "Camion1", "Camion2", "Camion3"};
  return noms[v];
}

String labelType(int v) {
  String[] labels = {"", "V t1", "C1 t1", "C2 t2", "C3 t3"};
  return labels[v];
}

// ============================================
// Actions Event-B
// ============================================

void verifResa() {
  if (etape != 0) { msg = "! Cliquez le bouton vert !"; return; }
  if (tete >= nbFile) {
    msg = "File vide ! Ajoutez des vehicules.";
    autoMode = false; return;
  }
  if (!resas[tete]) {
    msg = "Resa INVALIDE -> " + nomType(file[tete]) + " redirige vers voie laterale !";
    tete++; return;
  }
  permission = true;
  msg = "Resa OK (" + nomType(file[tete]) + " taille "
      + taille(file[tete]) + ") -> Ouvrez l entree";
  etape = 1;
}

void ouvrirEntree() {
  if (etape != 1) { msg = "! Cliquez le bouton vert !"; return; }
  if (!mcBouge && niveau == 0 && !barrEntree && !barrSortie) {
    barrEntree = true;
    msg = "Entree ouverte -> Chargez le MC";
    etape = 2;
  } else {
    msg = "MC doit etre arrete au Pont 1 !";
  }
}

void chargerMC() {
  if (etape != 2) { msg = "! Cliquez le bouton vert !"; return; }
  if (tete >= nbFile) { msg = "File vide !"; return; }
  int v = file[tete];
  int t = taille(v);
  if (!mcBouge && niveau == 0 && barrEntree && permission && placesMC + t <= 6) {
    placesMC += t;
    vMC[nMC] = v; nMC++;
    tete++; permission = false; barrEntree = false;
    if (tete < nbFile && resas[tete] && placesMC + taille(file[tete]) <= 6) {
      msg = "MC: " + placesMC + "/6 -> Verifiez le suivant ou passez a la sortie";
      etape = 0;
    } else {
      msg = "MC charge (" + placesMC + "/6) -> Ouvrez la sortie";
      etape = 3;
    }
  } else {
    msg = "Impossible de charger !";
  }
}

void ouvrirSortie() {
  if (etape != 3) { 
    msg = "! Cliquez le bouton vert !"; 
    return; 
  }
  
  if (mcBouge || barrSortie || barrEntree || placesMC == 0) {
    msg = "Impossible d'ouvrir la sortie !";
    return;
  }

  int tailleProchain = (nMC > 0) ? taille(vMC[0]) : 0;

  // ====================== PONT 1 ======================
  if (niveau == 0 && pont1 < N && tailleProchain <= (N - pont1)) {
    barrSortie = true;
    msg = "Sortie ouverte -> Montez sur Pont 1";
    etape = 4;
    return;
  }
  if (pont1 < N && niveau != 0) {
    msg = "Pont 1 disponible -> Ramenez le MC au Pont 1";
    etape = 7;
    return;
  }

  // ====================== PONT 2 ======================
  if (niveau == 1 && pont2 < N && tailleProchain <= (N - pont2)) {
    barrSortie = true;
    msg = "Sortie ouverte -> Montez sur Pont 2";
    etape = 4;
    return;
  }
  if (pont2 < N && niveau != 1) {
    msg = "Direction Pont 2";
    etape = 5;
    return;
  }

  // ====================== PONT 3 ======================
  if (niveau == 2 && pont3 < N && tailleProchain <= (N - pont3)) {
    barrSortie = true;
    msg = "Sortie ouverte -> Montez sur Pont 3";
    etape = 4;
    return;
  }
  if (pont3 < N && niveau != 2) {
    msg = "Direction Pont 3";
    etape = 6;
    return;
  }

  msg = "Aucun pont ne peut accueillir le véhicule actuel !";
}

void monterPont() {
  if (etape != 4) { 
    msg = "! Cliquez le bouton vert !"; 
    return; 
  }
  
  if (nMC == 0) { 
    msg = "MC vide !"; 
    return; 
  }

  int v = vMC[0];
  int t = taille(v);
  boolean ok = false;

  // Tentative de déchargement sur le pont actuel
  if (niveau == 0 && !mcBouge && barrSortie && pont1 + t <= N) {
    pont1 += t; 
    placesMC -= t;
    vP1[nP1] = v; 
    nP1++; 
    ok = true;
  } 
  else if (niveau == 1 && !mcBouge && barrSortie && pont2 + t <= N) {
    pont2 += t; 
    placesMC -= t;
    vP2[nP2] = v; 
    nP2++; 
    ok = true;
  } 
  else if (niveau == 2 && !mcBouge && barrSortie && pont3 + t <= N) {
    pont3 += t; 
    placesMC -= t;
    vP3[nP3] = v; 
    nP3++; 
    ok = true;
  }

  if (ok) {
    retirerMC();

    if (nMC > 0) {
      // Il reste encore des véhicules dans le MC
      int pontActuel = (niveau == 0) ? pont1 : (niveau == 1) ? pont2 : pont3;
      int tailleSuivant = taille(vMC[0]);

      if (pontActuel + tailleSuivant <= N) {
        msg = nomType(v) + " sur Pont " + (niveau + 1) + ". MC:" + placesMC + "/6 -> Continuez";
        etape = 4;
      } else {
        barrSortie = false;
        msg = "Pont " + (niveau + 1) + " plein pour le prochain véhicule -> Ouvrez la sortie";
        etape = 3;
      }
    } 
    else {
      // === MC DEVENU VIDE ===
      barrSortie = false;

      if (tete < nbFile) {
        // Il reste des véhicules dans la file
        if (niveau != 0) {
          msg = "MC vide -> Retour automatique au Pont 1";
          etape = 7;
          versPont1();        // Déclenche immédiatement le mouvement
        } else {
          msg = "MC vide -> Prêt pour un nouveau véhicule";
          etape = 0;
        }
      } else {
        // Plus aucun véhicule à charger
        msg = "Tous les véhicules ont embarqué !";
        autoMode = false; 
        etape = 0;
      }
    }
  } 
  else {
    msg = "Conditions non remplies pour monter sur le pont !";
  }
}

void versPont2() {
  if (etape != 5) { 
    msg = "! Cliquez le bouton vert !"; 
    return; 
  }
  
  if (!mcBouge && niveau != 1 && placesMC > 0 && !barrEntree && !barrSortie) {
    mcBouge = true; 
    niveau = 1; 
    mcYcible = 280;
    msg = "MC en route vers Pont 2...";
    etape = 4;           // passe directement à déchargement
  } else {
    msg = "Impossible de déplacer le MC !";
  }
}

void versPont3() {
  if (etape != 6) { 
    msg = "! Cliquez le bouton vert !"; 
    return; 
  }
  
  if (!mcBouge && niveau != 2 && placesMC > 0 && !barrEntree && !barrSortie) {
    mcBouge = true; 
    niveau = 2; 
    mcYcible = 140;
    msg = "MC en route vers Pont 3...";
    etape = 4;           
  } else {
    msg = "Impossible de déplacer le MC !";
  }
}

void versPont1() {
  if (!mcBouge && niveau != 0 && !barrEntree && !barrSortie) {
    mcBouge = true; 
    niveau = 0; 
    mcYcible = 420;
    msg = "MC en route vers Pont 1...";
    etape = (nMC > 0) ? 4 : 0;   // Si MC pas vide → on décharge, sinon on revient à l'étape 0
  } else {
    msg = "Impossible de déplacer le MC !";
  }
}

void retirerMC() {
  for (int i = 0; i < nMC - 1; i++) vMC[i] = vMC[i+1];
  nMC--;
}

void reset() {
  pont1=0; pont2=0; pont3=0;
  niveau=0; mcBouge=false; placesMC=0;
  barrEntree=false; barrSortie=false; permission=false;
  mcY=420; mcYcible=420;
  nP1=0; nP2=0; nP3=0; nMC=0;
  tete=0; nbFile=0; etape=0; autoMode=false;
  msg = "Reinitialise ! Ajoutez des vehicules.";
}

// ============================================
// DRAW
// ============================================
void draw() {
  background(25, 50, 90);
  
  // Animation du monte-charge
  mcY += (mcYcible - mcY) * 0.06;
  
  // Détection de l'arrêt du MC
  if (abs(mcY - mcYcible) < 1 && mcBouge) {
    mcBouge = false;
    
    if (nMC > 0) {
      // MC arrivé avec véhicule(s) → on prépare le déchargement automatique
      barrSortie = true;
      msg = "MC arrivé au Pont " + (niveau+1) + " -> Déchargement en cours";
      etape = 4;                    // Force le mode "Monter Pont"
    } 
    else if (niveau == 0) {
      msg = "MC vide et positionné au Pont 1 -> Prêt pour nouveau véhicule";
      etape = 0;
    } 
    else {
      msg = "MC arrete au Pont " + (niveau+1);
    }
  }

  // Mode Auto
  if (autoMode) {
    autoTimer++;
    if (autoTimer > 45 && !mcBouge && !popup) {
      autoTimer = 0;
      faireEtape();
    }
  }

  // Dessins
  dessinerMer();
  dessinerBateau();
  dessinerMC();
  dessinerFile();
  dessinerBoutons();
  dessinerInfos();
  
  if (popup) dessinerPopup();
}

// ============================================
String consigne() {
  String[] c = {
    "Verifiez la reservation",
    "Ouvrez la barriere d entree",
    "Chargez le MC",
    "Ouvrez la barriere de sortie",
    "Faites monter le vehicule",
    "Deplacez le MC vers Pont 2",
    "Deplacez le MC vers Pont 3",
    "Ramenez le MC au Pont 1"
  };
  return c[etape];
}

void faireEtape() {
  switch(etape) {
    case 0: verifResa(); break;
    case 1: ouvrirEntree(); break;
    case 2: chargerMC(); break;
    case 3: ouvrirSortie(); break;
    case 4: monterPont(); break;
    case 5: versPont2(); break;
    case 6: versPont3(); break;
    case 7: versPont1(); break;
  }
}

// ============================================
// MER
// ============================================
void dessinerMer() {
  fill(15, 70, 150); noStroke();
  rect(0, 510, width, 110);
  stroke(80, 160, 255, 80); strokeWeight(2);
  for (int i = 0; i < 3; i++)
    line(0, 525+i*15+sin(frameCount*0.03+i)*4,
         width, 525+i*15+sin(frameCount*0.03+i+1)*4);
}


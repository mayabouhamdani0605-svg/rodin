machine M5
refines M4
sees cont

variables
	places_pont1
	places_pont2
	places_pont3
	niveau_mc
	etat_mc
	places_mc
	barr_file1
	barr_file2
	barr_mc_entree
	barr_mc_sortie
	file1
	file2
	permission_envoyee
	pont_cible_actuel

invariants
	@inv1	places_pont1 ∈ ℤ
	@inv2	places_pont2 ∈ ℤ
	@inv3	places_pont3 ∈ ℤ
	@inv4	niveau_mc ∈ {0, 1, 2}
	@inv5	etat_mc ∈ BOOL
	@inv6	places_mc ∈ ℤ
	@inv7	places_mc ≥ 0
	@inv8	places_mc ≤ 6
	@inv9	places_pont1 ≥ 0
	@inv10	places_pont1 ≤ N
	@inv11	places_pont2 ≥ 0
	@inv12	places_pont2 ≤ N
	@inv13	places_pont3 ≥ 0
	@inv14	places_pont3 ≤ N
	@inv15	barr_file1 ∈ BOOL
	@inv16	barr_file2 ∈ BOOL
	@inv17	barr_mc_entree ∈ BOOL
	@inv18	barr_mc_sortie ∈ BOOL
	@inv19	file1 ⊆ VEHICULE
	@inv20	file2 ⊆ VEHICULE
	@inv21	∀ x · x ∈ file1 ⇒ x ∉ file2
	@inv22	∀ x · x ∈ file2 ⇒ x ∉ file1
	@inv23	permission_envoyee ∈ BOOL
	@inv24	pont_cible_actuel ∈ VEHICULE ⇸ PONT

events

 event INITIALISATION
	then
		@act1	places_pont1 ≔ 0
		@act2	places_pont2 ≔ 0
		@act3	places_pont3 ≔ 0
		@act4	niveau_mc ≔ 0
		@act5	etat_mc ≔ FALSE
		@act6	places_mc ≔ 0
		@act7	barr_file1 ≔ FALSE
		@act8	barr_file2 ≔ FALSE
		@act9	barr_mc_entree ≔ FALSE
		@act10	barr_mc_sortie ≔ FALSE
		@act11	file1 ≔ ∅
		@act12	file2 ≔ ∅
		@act13	permission_envoyee ≔ FALSE
		@act14	pont_cible_actuel ≔ ∅
 end

 event arrivee_vehicule_file1
	refines arrivee_vehicule_file1
	any
		v
	where
		@grd1	v ∈ VEHICULE
		@grd2	v ∉ file1
		@grd3	v ∉ file2
		@grd4	∀ x · x ∈ file1 ⇒ x ∉ file2
		@grd5	v ∉ dom(pont_cible_actuel)
	then
		@act1	file1 ≔ file1 ∪ {v}
		@act2	pont_cible_actuel ≔ pont_cible_actuel ∪ {v ↦ pont_cible(v)}
 end

 event arrivee_vehicule_file2
	refines arrivee_vehicule_file2
	any
		v
	where
		@grd1	v ∈ VEHICULE
		@grd2	v ∉ file1
		@grd3	v ∉ file2
		@grd4	∀ x · x ∈ file2 ⇒ x ∉ file1
		@grd5	v ∉ dom(pont_cible_actuel)
	then
		@act1	file2 ≔ file2 ∪ {v}
		@act2	pont_cible_actuel ≔ pont_cible_actuel ∪ {v ↦ pont_cible(v)}
 end

 event charger_mc
	refines charger_mc
	any
		v
		veh
	where
		@grd1	v ∈ TYPE_VEHICULE
		@grd2	etat_mc = FALSE
		@grd3	niveau_mc = 0
		@grd4	places_mc + taille(v) ≤ 6
		@grd5	barr_mc_entree = TRUE
		@grd6	permission_envoyee = TRUE
		@grd7	veh ∈ VEHICULE
		@grd8	v = type_vehicule(veh)
		@grd9	veh ∈ dom(pont_cible_actuel)
		@grd10	veh ∈ file1 ∨ veh ∈ file2
		@grd11	reservation(veh) = valide
	then
		@act1	places_mc ≔ places_mc + taille(v)
		@act2	pont_cible_actuel ≔ {veh} ⩤ pont_cible_actuel
		@act3	permission_envoyee ≔ FALSE
		@act4	file1 ≔ file1 ∖ {veh}
		@act5	file2 ≔ file2 ∖ {veh}
end



 event monter_pont1
	refines monter_pont1
	any
		v
	where
		@grd1	v ∈ TYPE_VEHICULE
		@grd2	etat_mc = FALSE
		@grd3	niveau_mc = 0
		@grd4	places_mc ≥ taille(v)
		@grd5	places_pont1 + taille(v) ≤ N
		@grd6	places_mc − taille(v) ≥ 0
		@grd7	places_mc − taille(v) ≤ 6
		@grd8	taille(v) > 0
		@grd9	barr_mc_sortie = TRUE
		@grd10	permission_envoyee = TRUE
	then
		@act1	places_mc ≔ places_mc − taille(v)
		@act2	places_pont1 ≔ places_pont1 + taille(v)
		@act3	permission_envoyee ≔ FALSE
 end

 event monter_pont2
	refines monter_pont2
	any
		v
	where
		@grd1	v ∈ TYPE_VEHICULE
		@grd2	etat_mc = FALSE
		@grd3	niveau_mc = 1
		@grd4	places_mc ≥ taille(v)
		@grd5	places_pont1 = N
		@grd6	places_pont2 + taille(v) ≤ N
		@grd7	places_mc − taille(v) ≥ 0
		@grd8	places_mc − taille(v) ≤ 6
		@grd9	taille(v) > 0
		@grd10	barr_mc_sortie = TRUE
		@grd11	permission_envoyee = TRUE
	then
		@act1	places_mc ≔ places_mc − taille(v)
		@act2	places_pont2 ≔ places_pont2 + taille(v)
		@act3	permission_envoyee ≔ FALSE
 end

 event monter_pont3
	refines monter_pont3
	any
		v
	where
		@grd1	v ∈ TYPE_VEHICULE
		@grd2	etat_mc = FALSE
		@grd3	niveau_mc = 2
		@grd4	places_mc ≥ taille(v)
		@grd5	places_pont2 = N
		@grd6	places_pont3 + taille(v) ≤ N
		@grd7	places_mc − taille(v) ≥ 0
		@grd8	places_mc − taille(v) ≤ 6
		@grd9	taille(v) > 0
		@grd10	barr_mc_sortie = TRUE
		@grd11	permission_envoyee = TRUE
	then
		@act1	places_mc ≔ places_mc − taille(v)
		@act2	places_pont3 ≔ places_pont3 + taille(v)
		@act3	permission_envoyee ≔ FALSE
 end

 event deplacement_vers_pont1
	refines deplacement_vers_pont1
	where
		@grd1	etat_mc = FALSE
		@grd2	niveau_mc ≠ 0
		@grd3	places_mc > 0
		@grd4	barr_file1 = FALSE
		@grd5	barr_file2 = FALSE
		@grd6	barr_mc_entree = FALSE
		@grd7	barr_mc_sortie = FALSE
	then
		@act1	etat_mc ≔ TRUE
		@act2	niveau_mc ≔ 0
 end

 event deplacement_vers_pont2
	refines deplacement_vers_pont2
	where
		@grd1	etat_mc = FALSE
		@grd2	niveau_mc ≠ 1
		@grd3	places_mc > 0
		@grd4	barr_file1 = FALSE
		@grd5	barr_file2 = FALSE
		@grd6	barr_mc_entree = FALSE
		@grd7	barr_mc_sortie = FALSE
	then
		@act1	etat_mc ≔ TRUE
		@act2	niveau_mc ≔ 1
 end

 event deplacement_vers_pont3
	refines deplacement_vers_pont3
	where
		@grd1	etat_mc = FALSE
		@grd2	niveau_mc ≠ 2
		@grd3	places_mc > 0
		@grd4	barr_file1 = FALSE
		@grd5	barr_file2 = FALSE
		@grd6	barr_mc_entree = FALSE
		@grd7	barr_mc_sortie = FALSE
	then
		@act1	etat_mc ≔ TRUE
		@act2	niveau_mc ≔ 2
 end

 event arret_monte_charge
	refines arret_monte_charge
	where
		@grd1	etat_mc = TRUE
	then
		@act1	etat_mc ≔ FALSE
 end

 event ouverture_barr_file1
	refines ouverture_barr_file1
	where
		@grd1	etat_mc = FALSE
		@grd2	niveau_mc = 0
		@grd3	barr_file1 = FALSE
		@grd4	barr_mc_entree = FALSE
		@grd5	barr_mc_sortie = FALSE
		@grd6	places_mc < 6
	then
		@act1	barr_file1 ≔ TRUE
 end

 event fermeture_barr_file1
	refines fermeture_barr_file1
	where
		@grd1	barr_file1 = TRUE
	then
		@act1	barr_file1 ≔ FALSE
 end

 event ouverture_barr_file2
	refines ouverture_barr_file2
	where
		@grd1	etat_mc = FALSE
		@grd2	niveau_mc = 0
		@grd3	barr_file2 = FALSE
		@grd4	barr_mc_entree = FALSE
		@grd5	barr_mc_sortie = FALSE
		@grd6	places_mc < 6
	then
		@act1	barr_file2 ≔ TRUE
 end

 event fermeture_barr_file2
	refines fermeture_barr_file2
	where
		@grd1	barr_file2 = TRUE
	then
		@act1	barr_file2 ≔ FALSE
 end

 event ouverture_barr_mc_entree
	refines ouverture_barr_mc_entree
	where
		@grd1	etat_mc = FALSE
		@grd2	niveau_mc = 0
		@grd3	barr_mc_entree = FALSE
		@grd4	barr_file1 = TRUE
		@grd5	barr_file2 = TRUE
	then
		@act1	barr_mc_entree ≔ TRUE
 end

 event fermeture_barr_mc_entree
	refines fermeture_barr_mc_entree
	where
		@grd1	barr_mc_entree = TRUE
	then
		@act1	barr_mc_entree ≔ FALSE
 end

 event ouverture_barr_mc_sortie
	refines ouverture_barr_mc_sortie
	where
		@grd1	etat_mc = FALSE
		@grd2	barr_mc_sortie = FALSE
		@grd3	barr_file1 = FALSE
		@grd4	barr_file2 = FALSE
		@grd5	places_mc > 0
	then
		@act1	barr_mc_sortie ≔ TRUE
 end

 event fermeture_barr_mc_sortie
	refines fermeture_barr_mc_sortie
	where
		@grd1	barr_mc_sortie = TRUE
	then
		@act1	barr_mc_sortie ≔ FALSE
 end

 event verification_reservation
	refines verification_reservation
	any
		v
	where
		@grd1	v ∈ VEHICULE
		@grd2	reservation(v) = valide
		@grd3	permission_envoyee = FALSE
	then
		@act1	permission_envoyee ≔ TRUE
 end

 event rejet_vehicule
	refines rejet_vehicule
	any
		v
	where
		@grd1	v ∈ VEHICULE
		@grd2	reservation(v) = invalide
		@grd3	v ∈ file1
 end

 event redirection_vehicule
	refines redirection_vehicule
	any
		v
	where
		@grd1	v ∈ VEHICULE
		@grd2	reservation(v) = invalide
		@grd3	permission_envoyee = FALSE
		@grd4	v ∈ file2
 end

 event redirection_camion_pont2
	refines redirection_camion_pont2
	any
		v
	where
		@grd1	v ∈ VEHICULE
		@grd2	reservation(v) = valide
		@grd3	v ∈ dom(pont_cible_actuel)
		@grd4	pont_cible_actuel(v) = pont_1
		@grd5	places_pont1 = N
		@grd6	places_pont2 < N
	then
		@act1	pont_cible_actuel(v) ≔ pont_2
 end

 event redirection_camion_pont3
	refines redirection_camion_pont3
	any
		v
	where
		@grd1	v ∈ VEHICULE
		@grd2	reservation(v) = valide
		@grd3	v ∈ dom(pont_cible_actuel)
		@grd4	pont_cible_actuel(v) = pont_2
		@grd5	places_pont2 = N
		@grd6	places_pont3 < N
	then
		@act1	pont_cible_actuel(v) ≔ pont_3
 end

end

MACHINE
  M2
REFINES
  M1
SEES
  cont

VARIABLES
  places_pont1
  places_pont2
  places_pont3
  niveau_mc
  etat_mc
  places_mc
  file1
  file2

INVARIANTS
  inv1: file1 ∈ seq(VEHICULE) not theorem
  inv2: file2 ∈ seq(VEHICULE) not theorem
  inv3: ran(file1) ∩ ran(file2) = ∅ not theorem

EVENTS
  INITIALISATION: not extended ordinary
    THEN
      act1: places_pont1 = 0
      act2: places_pont2 = 0
      act3: places_pont3 = 0
      act4: niveau_mc = 0
      act5: etat_mc = arret
      act6: places_mc = 0
      act7: file1 = ⟨ ⟩
      act8: file2 = ⟨ ⟩
    END

  arrivee_vehicule_file1: not extended ordinary
    ANY
      v
    WHERE
      grd1: v ∈ VEHICULE not theorem
      grd2: v ∉ ran(file1) not theorem
      grd3: v ∉ ran(file2) not theorem
    THEN
      act1: file1 = file1 ⌢ ⟨v⟩
    END

  arrivee_vehicule_file2: not extended ordinary
    ANY
      v
    WHERE
      grd1: v ∈ VEHICULE not theorem
      grd2: v ∉ ran(file1) not theorem
      grd3: v ∉ ran(file2) not theorem
    THEN
      act1: file2 = file2 ⌢ ⟨v⟩
    END

END

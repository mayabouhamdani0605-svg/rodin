// ============================================
// POPUP
// ============================================

void dessinerPopup() {

  fill(0, 0, 0, 155);
  rect(0, 0, width, height);

  float px = width / 2 - 210;
  float py = height / 2 - 170;

  fill(28, 28, 52);
  rect(px, py, 420, 340, 10);

  fill(255, 215, 90);
  textAlign(CENTER);
  textSize(15);

  text("Ajouter un vehicule", width / 2, py + 28);

  String[] noms2 = {
    "Voiture",
    "Camion1",
    "Camion2",
    "Camion3"
  };

  for (int i = 0; i < 4; i++) {

    float tx = px + 15 + (i % 2) * 200;
    float ty = py + 60 + (i / 2) * 115;

    fill(70, 70, 160);
    rect(tx, ty, 185, 100, 8);

    dessinerVeh(i + 1, tx + 12, ty + 32);

    fill(255);
    textAlign(LEFT);

    text(noms2[i], tx + 72, ty + 48);
    text("Clic = File 1", tx + 72, ty + 68);
    text("Shift = File 2", tx + 72, ty + 84);
  }
}

// ============================================
// CLICS
// ============================================

void mousePressed() {

  if (popup) {

    float px = width / 2 - 210;
    float py = height / 2 - 170;

    for (int i = 0; i < 4; i++) {

      float tx = px + 15 + (i % 2) * 200;
      float ty = py + 60 + (i / 2) * 115;

      if (mouseX > tx && mouseX < tx + 185
        && mouseY > ty && mouseY < ty + 100) {

        int fileChoisie = (keyPressed && keyCode == SHIFT) ? 2 : 1;

        addVeh(i + 1, true, fileChoisie);

        msg = nomType(i + 1) + " ajoute dans File " + fileChoisie;

        popup = false;
        return;
      }
    }

    return;
  }

  for (int i = 0; i < 8; i++) {

    float bx = 10 + (i % 5) * 115;
    float by = (i < 5) ? height - 88 : height - 44;

    if (mouseX > bx && mouseX < bx + 108
      && mouseY > by && mouseY < by + 36) {

      autoMode = false;
      faireEtapeNum(i);
      return;
    }
  }

  // Ajouter
  if (mouseX > width - 132 && mouseX < width - 7
    && mouseY > height - 140 && mouseY < height - 104) {

    popup = true;
    return;
  }

  // Auto
  if (mouseX > width - 132 && mouseX < width - 7
    && mouseY > height - 92 && mouseY < height - 56) {

    autoMode = !autoMode;

    msg = autoMode ? "Mode auto active" : "Auto pause";

    return;
  }

  // Reset
  if (mouseX > width - 132 && mouseX < width - 7
    && mouseY > height - 44 && mouseY < height - 8) {

    reset();
    return;
  }
}


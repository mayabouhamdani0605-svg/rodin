MACHINE
  M2
REFINES
  M1
SEES
  cont
VARIABLES
  places_pont1
  places_pont2
  places_pont3
  niveau_mc
  etat_mc
  places_mc
  file1
  file2
INVARIANTS
  inv1: file1 ⊆ VEHICULE not theorem
  inv2: file2 ⊆ VEHICULE not theorem
  inv3: file1 ∩ file2 = ∅ not theorem

EVENTS

  INITIALISATION: extended ordinary
  THEN
    act1: places_pont1 ≔ 0
    act2: places_pont2 ≔ 0
    act3: places_pont3 ≔ 0
    act4: niveau_mc ≔ 0
    act5: etat_mc ≔ FALSE
    act6: places_mc ≔ 0
    act7: file1 ≔ ∅
    act8: file2 ≔ ∅
  END

  arrivee_vehicule_file1: not extended ordinary
  ANY
    v
  WHERE
    grd1: v ∈ VEHICULE not theorem
    grd2: v ∉ file1 not theorem
    grd3: v ∉ file2 not theorem
  THEN
    act1: file1 ≔ file1 ∪ {v}
  END

  arrivee_vehicule_file2: not extended ordinary
  ANY
    v
  WHERE
    grd1: v ∈ VEHICULE not theorem
    grd2: v ∉ file1 not theorem
    grd3: v ∉ file2 not theorem
  THEN
    act1: file2 ≔ file2 ∪ {v}
  END

  deplacement_vers_pont2: extended ordinary
  REFINES
    deplacement_vers_pont2
  WHERE
    grd1: etat_mc = FALSE not theorem
    grd2: niveau_mc ≠ 1 not theorem
    grd3: places_mc > 0 not theorem
  THEN
    act1: etat_mc ≔ TRUE
    act2: niveau_mc ≔ 1
  END

  deplacement_vers_pont3: extended ordinary
  REFINES
    deplacement_vers_pont3
  WHERE
    grd1: etat_mc = FALSE not theorem
    grd2: niveau_mc ≠ 2 not theorem
    grd3: places_mc > 0 not theorem
  THEN
    act1: etat_mc ≔ TRUE
    act2: niveau_mc ≔ 2
  END
  deplacement_vers_pont1: extended ordinary
  REFINES
    deplacement_vers_pont1
  WHERE
    grd1: etat_mc = FALSE not theorem
    grd2: niveau_mc ≠ 0 not theorem
  THEN
    act1: etat_mc ≔ TRUE
    act2: niveau_mc ≔ 0
  END

  arret_monte_charge: extended ordinary
  REFINES
    arret_monte_charge
  WHERE
    grd1: etat_mc = TRUE not theorem
  THEN
    act1: etat_mc ≔ FALSE
  END

  charger_mc: extended ordinary
  REFINES
    charger_mc
  ANY
    v
  WHERE
    grd1: v ∈ TYPE_VEHICULE not theorem
    grd2: etat_mc = FALSE not theorem
    grd3: niveau_mc = 0 not theorem
    grd4: places_mc + taille(v) ≤ 6 not theorem
  THEN
    act1: places_mc ≔ places_mc + taille(v)
  END

  monter_pont1: extended ordinary
  REFINES
    monter_pont1
  ANY
    v
  WHERE
    grd1: v ∈ TYPE_VEHICULE not theorem
    grd2: etat_mc = FALSE not theorem
    grd4: places_mc ≥ taille(v) not theorem
    grd5: places_pont1 + taille(v) ≤ N not theorem
    grd6: places_mc - taille(v) ≥ 0 not theorem
    grd7: places_mc - taille(v) ≤ 6 not theorem
    grd8: taille(v) > 0 not theorem
  THEN
    act1: places_mc ≔ places_mc - taille(v)
    act2: places_pont1 ≔ places_pont1 + taille(v)
  END

  monter_pont2: extended ordinary
  REFINES
    monter_pont2
  ANY
    v
  WHERE
    grd1: v ∈ TYPE_VEHICULE not theorem
    grd2: etat_mc = FALSE not theorem
    grd3: niveau_mc = 1 not theorem
    grd4: places_mc ≥ taille(v) not theorem
    grd5: places_pont1 = N not theorem
    grd6: places_pont2 + taille(v) ≤ N not theorem
    grd7: places_mc - taille(v) ≥ 0 not theorem
    grd8: places_mc - taille(v) ≤ 6 not theorem
    grd9: taille(v) > 0 not theorem
  THEN
    act1: places_mc ≔ places_mc - taille(v)
    act2: places_pont2 ≔ places_pont2 + taille(v)
  END
  monter_pont3: extended ordinary
  REFINES
    monter_pont3
  ANY
    v
  WHERE
    grd1: v ∈ TYPE_VEHICULE not theorem
    grd2: etat_mc = FALSE not theorem
    grd3: niveau_mc = 2 not theorem
    grd4: places_mc ≥ taille(v) not theorem
    grd5: places_pont2 = N not theorem
    grd6: places_pont3 + taille(v) ≤ N not theorem
    grd7: places_mc - taille(v) ≥ 0 not theorem
    grd8: places_mc - taille(v) ≤ 6 not theorem
    grd9: taille(v) > 0 not theorem
  THEN
    act1: places_mc ≔ places_mc - taille(v)
    act2: places_pont3 ≔ places_pont3 + taille(v)
  END

END

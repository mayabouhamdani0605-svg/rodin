context cont
extends C3
sets
	PONT
	ETAT_MC
	ETAT_BARERIERE
constants
	pont_1
	pont_2
	pont_3
	arret
	mouvement
	levee
	abaissee
	type_vehicule
	pont_cible
axioms
	@axm1	partition(PONT, {pont_1}, {pont_2}, {pont_3})
	@axm5	partition(ETAT_MC, {arret}, {mouvement})
	@axm6	arret ≠ mouvement
	@axm7	partition(ETAT_BARERIERE, {levee}, {abaissee})
	@axm8	levee ≠ abaissee
	@axm15	type_vehicule ∈ VEHICULE → TYPE_VEHICULE
	@axm16	pont_cible ∈ VEHICULE → PONT
	@axm19	reservation(v1) = valide
	@axm20	reservation(v2) = valide
	@axm21	reservation(v3) = valide
	@axm22	reservation(v4) = invalide
	@axm23	reservation(v5) = invalide
	@axm24	type_vehicule(v1) = voiture
	@axm25	type_vehicule(v2) = camion1
	@axm26	type_vehicule(v3) = camion2
	@axm27	type_vehicule(v4) = voiture
	@axm28	type_vehicule(v5) = camion3
	@axm29	pont_cible(v1) = pont_1
	@axm30	pont_cible(v2) = pont_1
	@axm31	pont_cible(v3) = pont_1
	@axm32	pont_cible(v4) = pont_1
	@axm33	pont_cible(v5) = pont_1
end

machine M2
refines M1
sees c0

variables
	places_pont1
	places_pont2
	places_pont3
	niveau_mc
	etat_mc
	places_mc
	file1
	file2

invariants
    @inv1	places_pont1 ∈ ℤ
	@inv2	places_pont2 ∈ ℤ
	@inv3	places_pont3 ∈ ℤ
	@inv4	niveau_mc ∈ {0, 1, 2}
	@inv5	etat_mc ∈ BOOL
	@inv6	places_mc ∈ ℤ
	@inv7	places_mc ≥ 0
	@inv8	places_mc ≤ 6
	@inv9	places_pont1 ≥ 0
	@inv10	places_pont1 ≤ N
	@inv11	places_pont2 ≥ 0
	@inv12	places_pont2 ≤ N
	@inv13	places_pont3 ≥ 0
	@inv14	places_pont3 ≤ N
	@inv15	file1 ⊆ VEHICULE
	@inv16	file2 ⊆ VEHICULE
	@inv17	∀ x · x ∈ file1 ⇒ x ∉ file2
    @inv18	∀ x · x ∈ file2 ⇒ x ∉ file1

events

 event INITIALISATION
	then
		@act1	places_pont1 ≔ 0
		@act2	places_pont2 ≔ 0
		@act3	places_pont3 ≔ 0
		@act4	niveau_mc ≔ 0
		@act5	etat_mc ≔ FALSE
		@act6	places_mc ≔ 0
		@act7	file1 ≔ ∅
		@act8	file2 ≔ ∅
 end

 event arrivee_vehicule_file1
	any
		v
	where
		@grd1	v ∈ VEHICULE
		@grd2	v ∉ file1
		@grd3	v ∉ file2
		@grd4	∀ x · x ∈ file1 ⇒ x ∉ file2
	then
		@act1	file1 ≔ file1 ∪ {v}
 end

 event arrivee_vehicule_file2
	any
		v
	where
		@grd1	v ∈ VEHICULE
		@grd2	v ∉ file1
		@grd3	v ∉ file2
		@grd4	∀ x · x ∈ file2 ⇒ x ∉ file1
	then
		@act1	file2 ≔ file2 ∪ {v}
 end

 event deplacement_vers_pont2
	refines deplacement_vers_pont2
	where
		@grd1	etat_mc = FALSE
		@grd2	niveau_mc ≠ 1
		@grd3	places_mc > 0
	then
		@act1	etat_mc ≔ TRUE
		@act2	niveau_mc ≔ 1
 end

 event deplacement_vers_pont3
	refines deplacement_vers_pont3
	where
		@grd1	etat_mc = FALSE
		@grd2	niveau_mc ≠ 2
		@grd3	places_mc > 0
	then
		@act1	etat_mc ≔ TRUE
		@act2	niveau_mc ≔ 2
 end

 event deplacement_vers_pont1
	refines deplacement_vers_pont1
	where
		@grd1	etat_mc = FALSE
		@grd2	niveau_mc ≠ 0
	then
		@act1	etat_mc ≔ TRUE
		@act2	niveau_mc ≔ 0
 end

 event arret_monte_charge
	refines arret_monte_charge
	where
		@grd1	etat_mc = TRUE
	then
		@act1	etat_mc ≔ FALSE
 end

 event charger_mc
	refines charger_mc
	any
		v
		veh
	where
		@grd1	v ∈ TYPE_VEHICULE
		@grd2	etat_mc = FALSE
		@grd3	niveau_mc = 0
		@grd4	places_mc + taille(v) ≤ 6
		@grd5	veh ∈ VEHICULE
		@grd6	veh ∈ file1 ∨ veh ∈ file2
	then
		@act1	places_mc ≔ places_mc + taille(v)
		@act2	file1 ≔ file1 ∖ {veh}
		@act3	file2 ≔ file2 ∖ {veh}
end

 event monter_pont1
	refines monter_pont1
	any
		v
	where
		@grd1	v ∈ TYPE_VEHICULE
		@grd2	etat_mc = FALSE
		@grd4	places_mc ≥ taille(v)
		@grd5	places_pont1 + taille(v) ≤ N
		@grd6	places_mc − taille(v) ≥ 0
		@grd7	places_mc − taille(v) ≤ 6
		@grd8	taille(v) > 0
	then
		@act1	places_mc ≔ places_mc − taille(v)
		@act2	places_pont1 ≔ places_pont1 + taille(v)
 end

 event monter_pont2
	refines monter_pont2
	any
		v
	where
		@grd1	v ∈ TYPE_VEHICULE
		@grd2	etat_mc = FALSE
		@grd3	niveau_mc = 1
		@grd4	places_mc ≥ taille(v)
		@grd5	places_pont1 = N
		@grd6	places_pont2 + taille(v) ≤ N
		@grd7	places_mc − taille(v) ≥ 0
		@grd8	places_mc − taille(v) ≤ 6
		@grd9	taille(v) > 0
	then
		@act1	places_mc ≔ places_mc − taille(v)
		@act2	places_pont2 ≔ places_pont2 + taille(v)
 end

 event monter_pont3
	refines monter_pont3
	any
		v
	where
		@grd1	v ∈ TYPE_VEHICULE
		@grd2	etat_mc = FALSE
		@grd3	niveau_mc = 2
		@grd4	places_mc ≥ taille(v)
		@grd5	places_pont2 = N
		@grd6	places_pont3 + taille(v) ≤ N
		@grd7	places_mc − taille(v) ≥ 0
		@grd8	places_mc − taille(v) ≤ 6
		@grd9	taille(v) > 0
	then
		@act1	places_mc ≔ places_mc − taille(v)
		@act2	places_pont3 ≔ places_pont3 + taille(v)
 end

end
